{
  "name": "@drvillo/react-browser-e-signing",
  "version": "0.6.2",
  "description": "React PDF e-signing in the browser — fields, handwriting, pdf-lib",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drvillo/react-browser-e-signing.git"
  },
  "homepage": "https://github.com/drvillo/react-browser-e-signing#readme",
  "bugs": "https://github.com/drvillo/react-browser-e-signing/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./worker": {
      "import": "./dist/worker.mjs",
      "types": "./dist/worker.d.mts"
    },
    "./pdf.worker.min.mjs": "./dist/pdf.worker.min.mjs",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "dist",
    "INTEGRATION_GUIDELINES.md"
  ],
  "scripts": {
    "postinstall": "pnpm run install:browsers",
    "install:browsers": "playwright install chromium",
    "build": "tsup && node scripts/copy-dist-assets.mjs",
    "dev": "tsup --watch",
    "demo": "node scripts/sync-fonts-to-src.mjs && node scripts/sync-worker-to-dev.mjs && vite",
    "demo:build": "node scripts/sync-fonts-to-src.mjs && node scripts/sync-worker-to-dev.mjs && vite build",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "verify:worker": "node scripts/verify-worker.mjs",
    "prepublishOnly": "npm run build && npm run verify:worker",
    "publish:npm": "npm publish"
  },
  "keywords": [
    "e-signature",
    "pdf",
    "sign",
    "browser",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "react-pdf": "^9.0.0",
    "signature_pad": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/homemade-apple": "^5.2.8",
    "@fontsource/mr-dafoe": "^5.2.8",
    "@fontsource/pacifico": "^5.2.7",
    "@fontsource/qwitcher-grypen": "^5.2.8",
    "@fontsource/reenie-beanie": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/browser-playwright": "^4.0.0",
    "happy-dom": "^20.0.0",
    "pdfjs-dist": "4.8.69",
    "playwright": "^1.55.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^4.0.0"
  }
}
